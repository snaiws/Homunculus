# ============================================================
# Homunculus - Environment Variables
# ============================================================
# 이 파일을 복사하여 .env로 만들고 값을 채우세요.
#   cp config/.env.example config/.env
# ============================================================

# --- LLM Provider ---
# 사용할 LLM 프로바이더의 API 키 (하나만 설정)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# 사용할 모델 (기본: anthropic/claude-sonnet-4-5)
LLM_MODEL=anthropic/claude-sonnet-4-5

# --- Gateway ---
# Gateway 인증 토큰 (임의의 문자열, 보안용)
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-random-string

# --- Discord ---
# Discord 봇 토큰 (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=
DISCORD_ENABLED=true

# --- Homunculus Identity ---
# 호문쿨루스의 이름과 이모지
HOMUNCULUS_NAME=호문쿨루스
HOMUNCULUS_EMOJI=🧪

# --- Logging ---
LOG_LEVEL=info
